# HireIQ Backend Environment Variables
# Copy this file to .env and fill in all values before running the server

# ── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL — found in Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to use for public operations
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER expose this to the frontend
# Used by the backend to bypass Row Level Security for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Your Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# ── Application ───────────────────────────────────────────────────────────────
# Environment: development | production
ENVIRONMENT=development

# Frontend URL for CORS — no trailing slash
FRONTEND_URL=http://localhost:3000

# Secret key for signing any internal tokens (generate with: openssl rand -hex 32)
SECRET_KEY=your-32-character-random-secret-key-here

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Max requests per minute per IP for general endpoints
RATE_LIMIT_GENERAL=100

# Max AI requests per minute per authenticated user
RATE_LIMIT_AI=20
